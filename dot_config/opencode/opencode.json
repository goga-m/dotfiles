{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "llama.cpp": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llm.puff.lan",
      "options": {
        "baseURL": "http://0.0.0.0:8080/v1",
        "includeUsage": true
      },
      "models": {
        "Local": {
          "name": "Local model",
          "options": {
            "temperature": 0.15,
            "max_tokens": 4096,
            "top_p": 0.95,
            "frequency_penalty": 0.1,
            "presence_penalty": 0.1
          }
        }
      }
    }
  },
  "plugin": [
    "@ramarivera/opencode-model-announcer"
  ],
  "autoupdate": true
}
