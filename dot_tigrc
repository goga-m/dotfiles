set main-view-id = yes

set ignore-case = yes

bind main R !git rebase -i %(commit)^
bind diff R !git rebase -i %(commit)^

bind main c !git checkout %(commit)

bind status S !git stash -k
bind status P !git push origin
bind status p !git pull origin
bind status w !git commit -m "wip"

# Remove untracked file from filesystem (and git's untracked list)
bind status D ?rm -f %(file)

# Revert commit with Ctrl+R
bind main <Ctrl-R> ?git revert %(commit)


# Vim-style navigation bindings
bind generic G move-last-line
bind generic gg move-first-line

# Vim-style navigation - unbind 'g' first to free up 'gg'
bind generic g none
bind generic gg move-first-line
bind generic G move-last-line


# Grab/Checkout specific file from a stash or commit
bind diff G ?git checkout %(commit) -- %(file)

# Grab/Checkout specific file from the stage view
bind stage G ?git checkout %(commit) -- %(file)

# To "pull" a change from a different branch diff into your current work,
# use 'A' to Apply the state of that file at that commit.
bind diff A !git checkout %(commit) -- %(file)


# Copy filepath under highlighted line in any view.
bind generic Y !@sh -c "echo -n %(file) | wl-copy"
